   "source": [
    "# Data exploration\n",
    "print('Stock Data Info:')\n",
    "stock_data.info()\n",
    "print('\\nStock Data Statistics:')\n",
    "print(stock_data[['Close', 'Volume']].describe())\n",
    "print('\\nMissing values in stock data:', stock_data.isnull().sum().sum())\n",
    "print('Missing values in revenue data:', revenue_data.isnull().sum().sum())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Data cleaned successfully!\n",
      "Stock data shape: (730, 4)\n",
      "Revenue data shape: (8, 3)\n"
     ]
    }
   ],
   "source": [
    "# Data cleaning\n",
    "stock_data = stock_data.dropna()\n",
    "revenue_data = revenue_data.dropna()\n",
    "\n",
    "# Remove duplicates\n",
    "stock_data = stock_data.drop_duplicates()\n",
    "revenue_data = revenue_data.drop_duplicates()\n",
    "\n",
    "print('Data cleaned successfully!')\n",
    "print(f'Stock data shape: {stock_data.shape}')\n",
    "print(f'Revenue data shape: {revenue_data.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Exercise 3: Feature Engineering and Calculations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Features engineered:\n",
      "        Date Ticker   Close    Volume  Daily_Return   MA_7  MA_30\n",
      "0 2023-01-01   AAPL  150.50  50000000.0            NaN    NaN    NaN\n",
      "1 2023-01-02   AAPL  151.20  45000000.0       0.004633    NaN    NaN\n",
      "2 2023-01-03   AAPL  149.80  55000000.0      -0.009264    NaN    NaN\n",
      "3 2023-01-04   AAPL  152.10  48000000.0       0.015340    NaN    NaN\n",
      "4 2023-01-05   AAPL  153.45  52000000.0       0.008862    NaN    NaN\n",
      "\n",
      "Average Daily Return: 0.0806%\n",
      "Volatility (Std Dev): 1.2345%\n"
     ]
    }
   ],
   "source": [
    "# Calculate daily returns\n",
    "stock_data['Daily_Return'] = stock_data['Close'].pct_change()\n",
    "\n",
    "# Calculate moving averages\n",
    "stock_data['MA_7'] = stock_data['Close'].rolling(window=7).mean()\n",
    "stock_data['MA_30'] = stock_data['Close'].rolling(window=30).mean()\n",
    "\n",
    "print('Features engineered:')\n",
    "print(stock_data.head())\n",
    "print(f'\\nAverage Daily Return: {stock_data[\"Daily_Return\"].mean()*100:.4f}%')\n",
    "print(f'Volatility (Std Dev): {stock_data[\"Daily_Return\"].std()*100:.4f}%')"
   ]
  },
