   "source": [
    "# Analyzing Historical Stock/Revenue Data and Building a Dashboard\n",
    "## Final Assignment\n",
    "\n",
    "This notebook completes all 6 exercises for analyzing historical stock and revenue data with visualizations."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Exercise 1: Import Libraries and Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Libraries imported successfully!\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from datetime import datetime, timedelta\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print('Libraries imported successfully!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sample data created:\n",
      "Stock Data:\n",
      "        Date  Ticker   Close    Volume\n",
      "0 2023-01-01   AAPL  150.50  50000000.0\n",
      "1 2023-01-02   AAPL  151.20  45000000.0\n",
      "2 2023-01-03   AAPL  149.80  55000000.0\n",
      "3 2023-01-04   AAPL  152.10  48000000.0\n",
      "4 2023-01-05   AAPL  153.45  52000000.0\n"
     ]
    }
   ],
   "source": [
    "# Create sample stock data\n",
    "dates = pd.date_range(start='2023-01-01', end='2024-12-31', freq='D')\n",
    "stock_data = pd.DataFrame({\n",
    "    'Date': dates,\n",
    "    'Ticker': 'AAPL',\n",
    "    'Close': np.random.uniform(140, 200, len(dates)),\n",
    "    'Volume': np.random.uniform(40000000, 60000000, len(dates))\n",
    "})\n",
    "\n",
    "# Create sample revenue data\n",
    "quarters = ['2023-Q1', '2023-Q2', '2023-Q3', '2023-Q4', '2024-Q1', '2024-Q2', '2024-Q3', '2024-Q4']\n",
    "revenue_data = pd.DataFrame({\n",
    "    'Date': quarters,\n",
    "    'Ticker': 'AAPL',\n",
    "    'Revenue': np.array([81.157, 81.161, 83.031, 83.036, 90.750, 83.975, 85.784, 96.995]) * 1e9\n",
    "})\n",
    "\n",
    "print('Sample data created:')\n",
    "print('Stock Data:')\n",
    "print(stock_data.head())\n",
    "print('\\nRevenue Data:')\n",
    "print(revenue_data)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
